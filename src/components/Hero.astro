---
---

<section id="inicio" class="hero">
	<div class="hero-inner">
		<div class="hero-content">
			<h1 class="hero-title">HEMA Las Rozas</h1>

			<div class="hero-divider">
				<span class="hero-divider-line"></span>
				<span class="hero-divider-ornament">◆</span>
				<span class="hero-divider-line"></span>
			</div>

			<p class="hero-subtitle">Arte Marcial Histórica Europea</p>

			<p class="hero-disciplines">
				Espada Larga · Ropera · Daga de Rodela
			</p>

			<p class="hero-location">Las Rozas de Madrid</p>

			<a href="#unete" class="cta-button">Únete al equipo</a>
		</div>

		<figure class="hero-image-wrap">
			<img
				src="/images/meyer-longsword.jpg"
				alt="Grabado de combatientes con espada larga, de El Arte del Combate de Joachim Meyer (1570)"
				class="hero-image"
				width="1024"
				height="686"
				loading="eager"
			/>
			<figcaption class="hero-image-caption">
				Joachim Meyer · <em>El Arte del Combate</em> · 1570
			</figcaption>
		</figure>
	</div>
</section>

<style>
	.hero {
		min-height: 100svh;
		display: flex;
		align-items: center;
		position: relative;
		padding: var(--space-8) var(--space-4);
		overflow: hidden;
	}

	.hero-inner {
		max-width: var(--max-width);
		margin: 0 auto;
		width: 100%;
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
		align-items: center;
	}

	@media (min-width: 768px) {
		.hero-inner {
			grid-template-columns: 1fr 1fr;
			gap: var(--space-12);
		}
	}

	.hero-content {
		animation: fadeInUp 1s ease forwards;
	}

	.hero-title {
		font-size: var(--font-size-hero);
		font-weight: 300;
		letter-spacing: -0.02em;
		color: var(--color-ink);
		margin-bottom: var(--space-6);
		line-height: 1.1;
	}

	.hero-divider {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-6);
		height: 2rem;
	}

	.hero-divider-line {
		display: block;
		width: 3rem;
		height: 1px;
		background-color: var(--color-gold);
	}

	.hero-divider-ornament {
		display: block;
		font-size: var(--font-size-xl);
		color: var(--color-gold);
		font-weight: bold;
		line-height: 1;
	}

	.hero-subtitle {
		font-family: var(--font-heading);
		font-size: var(--font-size-2xl);
		font-weight: 400;
		color: var(--color-accent);
		margin-bottom: var(--space-4);
		letter-spacing: 0.05em;
	}

	.hero-disciplines {
		font-family: var(--font-heading);
		font-size: var(--font-size-lg);
		color: var(--color-ink);
		margin-bottom: var(--space-3);
		font-weight: 300;
		letter-spacing: 0.03em;
	}

	.hero-location {
		font-size: var(--font-size-md);
		color: var(--color-ink-muted);
		margin-bottom: var(--space-8);
		font-weight: 300;
	}

	.cta-button {
		display: inline-block;
		padding: var(--space-3) var(--space-6);
		background-color: transparent;
		border: 2px solid var(--color-accent);
		color: var(--color-accent);
		text-decoration: none;
		font-family: var(--font-heading);
		font-size: var(--font-size-base);
		font-weight: 500;
		letter-spacing: 0.05em;
		cursor: pointer;
		transition: all var(--transition-base);
		border-radius: var(--border-radius);
	}

	.cta-button:hover {
		background-color: var(--color-accent);
		color: var(--color-surface);
		border-color: var(--color-accent-light);
		box-shadow: 0 4px 12px rgba(123, 31, 46, 0.2);
	}

	/* Image column */
	.hero-image-wrap {
		margin: 0;
		display: flex;
		flex-direction: column;
		align-items: center;
		animation: fadeInUp 1.2s ease forwards;
		border: var(--border-thin);
		background-color: var(--color-surface);
		padding: var(--space-2);
	}

	.hero-image {
		width: 100%;
		height: auto;
		display: block;
		filter: sepia(15%) contrast(1.05);
	}

	.hero-image-caption {
		font-family: var(--font-heading);
		font-size: var(--font-size-xs);
		color: var(--color-ink-muted);
		font-style: normal;
		text-align: center;
		padding: var(--space-2) 0 var(--space-1);
		letter-spacing: 0.03em;
	}

	.hero-image-caption em {
		font-style: italic;
	}

	/* Mobile: image goes below text */
	@media (max-width: 767px) {
		.hero {
			padding: var(--space-6) var(--space-3);
		}

		.hero-image-wrap {
			order: -1;
			max-height: 280px;
			overflow: hidden;
		}

		.hero-image {
			object-fit: cover;
			object-position: top;
			max-height: 260px;
		}
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(2rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

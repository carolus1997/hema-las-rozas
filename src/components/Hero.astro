---
---

<section id="inicio" class="hero">
	<div class="hero-overlay"></div>
	<div class="hero-content">
		<div class="hero-tag">Artes Marciales Históricas Europeas</div>
		<h1 class="hero-title">HEMA Las Rozas</h1>

		<div class="hero-divider">
			<span class="hero-line"></span>
			<span class="hero-ornament">◆</span>
			<span class="hero-line"></span>
		</div>

		<p class="hero-subtitle">Espada Larga · Ropera · Daga de Rodela</p>
		<p class="hero-location">Las Rozas de Madrid</p>

		<div class="hero-ctas">
			<a href="#unete" class="btn btn-primary">Únete al equipo</a>
			<a href="/teoria" class="btn btn-secondary">Conoce las HEMA</a>
		</div>
	</div>
</section>

<style>
	.hero {
		min-height: 100svh;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		padding: var(--space-8) var(--space-4);
		background-image: url('/images/meyer-longsword.jpg');
		background-size: cover;
		background-position: center 20%;
		background-attachment: fixed;
		overflow: hidden;
	}

	@media (max-width: 767px) {
		.hero {
			background-attachment: scroll;
			padding-top: 6rem;
			min-height: auto;
		}
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			rgba(0, 0, 0, 0.70) 0%,
			rgba(0, 0, 0, 0.55) 40%,
			rgba(0, 0, 0, 0.85) 100%
		);
		z-index: 1;
	}

	.hero-content {
		position: relative;
		z-index: 2;
		text-align: center;
		max-width: 900px;
		animation: fadeInUp 1s ease forwards;
	}

	.hero-tag {
		font-family: var(--font-heading);
		font-size: var(--font-size-xs);
		color: var(--color-accent);
		text-transform: uppercase;
		letter-spacing: 0.15em;
		margin-bottom: var(--space-4);
		font-weight: 600;
	}

	.hero-title {
		font-size: var(--font-size-hero);
		font-weight: 300;
		letter-spacing: -0.03em;
		color: var(--color-ink);
		margin-bottom: var(--space-6);
		line-height: 1.05;
	}

	.hero-divider {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: var(--space-3);
		margin-bottom: var(--space-6);
		height: 1.5rem;
	}

	.hero-line {
		display: block;
		width: 4rem;
		height: 1px;
		background-color: var(--color-gold);
	}

	.hero-ornament {
		display: block;
		font-size: var(--font-size-lg);
		color: var(--color-gold);
		font-weight: bold;
		line-height: 1;
	}

	.hero-subtitle {
		font-family: var(--font-heading);
		font-size: var(--font-size-lg);
		color: var(--color-ink);
		margin-bottom: var(--space-2);
		font-weight: 300;
		letter-spacing: 0.03em;
	}

	.hero-location {
		font-size: var(--font-size-md);
		color: var(--color-ink-muted);
		margin-bottom: var(--space-8);
		font-weight: 300;
	}

	.hero-ctas {
		display: flex;
		gap: var(--space-4);
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn {
		padding: var(--space-3) var(--space-6);
		font-family: var(--font-heading);
		font-size: var(--font-size-base);
		font-weight: 500;
		letter-spacing: 0.05em;
		text-decoration: none;
		cursor: pointer;
		border-radius: var(--border-radius);
		transition: all var(--transition-base);
		display: inline-block;
		text-transform: uppercase;
	}

	.btn-primary {
		background-color: var(--color-accent);
		color: var(--color-ink);
		border: 2px solid var(--color-accent);
	}

	.btn-primary:hover {
		background-color: var(--color-accent-light);
		border-color: var(--color-accent-light);
		box-shadow: 0 8px 24px rgba(196, 18, 48, 0.4);
		transform: translateY(-2px);
	}

	.btn-secondary {
		background-color: transparent;
		color: var(--color-ink);
		border: 2px solid var(--color-ink);
	}

	.btn-secondary:hover {
		background-color: var(--color-ink);
		color: var(--color-bg);
		border-color: var(--color-ink);
		box-shadow: 0 8px 24px rgba(240, 237, 232, 0.15);
		transform: translateY(-2px);
	}

	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(3rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>

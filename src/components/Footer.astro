---

<footer class="footer">
	<div class="footer-content">
		<p class="footer-text">
			<span class="footer-ornament-left">✦</span>
			© 2026 HEMA Las Rozas — Todos los derechos reservados
			<span class="footer-ornament-right">✦</span>
		</p>
		<p class="footer-contact">
			<a href="mailto:charlyp1397@gmail.com" class="footer-email">charlyp1397@gmail.com</a>
		</p>
	</div>
</footer>

<style>
	.footer {
		background-color: var(--color-bg);
		border-top: var(--border-thin);
		padding: var(--space-6) var(--space-4);
		text-align: center;
	}

	.footer-content {
		max-width: var(--max-width);
		margin: 0 auto;
	}

	.footer-text {
		font-size: var(--font-size-sm);
		color: var(--color-ink-muted);
		display: flex;
		justify-content: center;
		align-items: center;
		gap: var(--space-2);
		margin-bottom: var(--space-2);
		font-family: var(--font-heading);
		letter-spacing: 0.03em;
	}

	.footer-ornament-left,
	.footer-ornament-right {
		color: var(--color-gold);
		font-size: var(--font-size-xs);
	}

	.footer-contact {
		margin-bottom: 0;
	}

	.footer-email {
		color: var(--color-accent);
		text-decoration: none;
		font-size: var(--font-size-sm);
		font-weight: 500;
		transition: color var(--transition-base);
	}

	.footer-email:hover {
		color: var(--color-accent-light);
		text-decoration: underline;
	}

	@media (max-width: 767px) {
		.footer {
			padding: var(--space-4) var(--space-3);
		}

		.footer-text {
			flex-direction: column;
			gap: var(--space-1);
		}

		.footer-ornament-left,
		.footer-ornament-right {
			display: none;
		}
	}
</style>

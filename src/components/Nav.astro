<nav class="nav">
	<a href="/" class="nav-logo">HEMA</a>

	<button class="hamburger" aria-label="Abrir menú">
		<span></span>
		<span></span>
		<span></span>
	</button>

	<div class="nav-menu">
		<a href="/" class="nav-link">Inicio</a>
		<a href="/teoria" class="nav-link">Teoría</a>
		<a href="/espada-larga" class="nav-link">Espada Larga</a>
		<a href="/ropera" class="nav-link">Ropera</a>
		<a href="/daga-de-rodela" class="nav-link">Daga de Rodela</a>
		<a href="/#unete" class="nav-link">Únete</a>
		<a href="/#contacto" class="nav-link">Contacto</a>
	</div>
</nav>

<style>
	.nav {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: var(--space-3) var(--space-4);
		background-color: transparent;
		transition: background-color var(--transition-base), backdrop-filter var(--transition-base);
	}

	.nav.scrolled {
		background-color: rgba(8, 8, 8, 0.95);
		backdrop-filter: blur(4px);
		border-bottom: var(--border-thin);
	}

	.nav-logo {
		font-family: var(--font-heading);
		font-size: var(--font-size-2xl);
		color: var(--color-ink);
		font-weight: 600;
		text-decoration: none;
		letter-spacing: 0.08em;
		white-space: nowrap;
		transition: color var(--transition-base);
	}

	.nav-logo:hover {
		color: var(--color-gold);
	}

	.nav-menu {
		display: flex;
		gap: var(--space-6);
		align-items: center;
	}

	.nav-link {
		font-family: var(--font-heading);
		font-size: var(--font-size-sm);
		color: var(--color-ink);
		text-decoration: none;
		position: relative;
		padding: var(--space-1);
		transition: color var(--transition-base);
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}

	.nav-link:hover {
		color: var(--color-accent);
	}

	.nav-link[aria-current="true"] {
		color: var(--color-accent);
	}

	.hamburger {
		display: none;
		flex-direction: column;
		background: none;
		border: none;
		cursor: pointer;
		gap: 0.35rem;
		padding: var(--space-2);
	}

	.hamburger span {
		width: 1.5rem;
		height: 2px;
		background-color: var(--color-ink);
		transition: all var(--transition-base);
		display: block;
	}

	.hamburger.active span:nth-child(1) {
		transform: translateY(calc(0.35rem + 2px)) rotate(45deg);
	}

	.hamburger.active span:nth-child(2) {
		opacity: 0;
	}

	.hamburger.active span:nth-child(3) {
		transform: translateY(calc(-0.35rem - 2px)) rotate(-45deg);
	}

	/* Mobile menu overlay */
	@media (max-width: 767px) {
		.hamburger {
			display: flex;
		}

		.nav-menu {
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100vh;
			height: 100dvh;
			background-color: rgba(8, 8, 8, 0.98);
			backdrop-filter: blur(4px);
			flex-direction: column;
			justify-content: center;
			align-items: center;
			gap: var(--space-8);
			opacity: 0;
			pointer-events: none;
			visibility: hidden;
			transition: opacity var(--transition-base), visibility var(--transition-base);
			z-index: 999;
		}

		.nav-menu.active {
			opacity: 1;
			pointer-events: all;
			visibility: visible;
		}

		.nav-link {
			font-size: var(--font-size-lg);
		}

		.nav-logo {
			position: relative;
			z-index: 1001;
		}

		.hamburger {
			position: relative;
			z-index: 1001;
		}
	}
</style>

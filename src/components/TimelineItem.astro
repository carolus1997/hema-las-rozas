---
interface Props {
	year: string;
	title: string;
	body: string;
}

const { year, title, body } = Astro.props;
---

<div class="timeline-item">
	<div class="timeline-year">
		<span class="timeline-marker"></span>
		<span class="timeline-year-text">{year}</span>
	</div>
	<div class="timeline-content">
		<h4 class="timeline-title">{title}</h4>
		<p class="timeline-body">{body}</p>
	</div>
</div>

<style>
	.timeline-item {
		display: flex;
		gap: var(--space-4);
		position: relative;
		margin-bottom: var(--space-6);
	}

	.timeline-item::before {
		content: '';
		position: absolute;
		left: 0.375rem;
		top: 2.5rem;
		bottom: -3rem;
		width: 1px;
		background-color: var(--color-gold);
	}

	.timeline-item:last-child::before {
		display: none;
	}

	.timeline-year {
		position: relative;
		z-index: 2;
		flex-shrink: 0;
		width: 3rem;
		padding-top: 0.25rem;
	}

	.timeline-marker {
		display: block;
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		background-color: var(--color-accent);
		position: absolute;
		left: 0;
		top: 0;
		box-shadow: 0 0 0 3px var(--color-bg-alt);
	}

	.timeline-year-text {
		display: block;
		font-family: var(--font-heading);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		font-variant: small-caps;
		margin-left: var(--space-3);
		margin-top: -0.2rem;
		font-weight: 500;
	}

	.timeline-content {
		flex: 1;
		padding-top: 0.25rem;
	}

	.timeline-title {
		font-family: var(--font-heading);
		font-size: var(--font-size-base);
		font-weight: 600;
		color: var(--color-ink);
		margin-bottom: var(--space-1);
	}

	.timeline-body {
		font-size: var(--font-size-sm);
		color: var(--color-ink-muted);
		line-height: 1.5;
		margin-bottom: 0;
	}

	@media (max-width: 767px) {
		.timeline-item {
			gap: var(--space-2);
		}

		.timeline-year {
			width: 2.5rem;
		}

		.timeline-marker {
			width: 0.6rem;
			height: 0.6rem;
		}

		.timeline-year-text {
			font-size: var(--font-size-xs);
			margin-left: var(--space-2);
		}
	}
</style>

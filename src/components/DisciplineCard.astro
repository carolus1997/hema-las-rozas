---
interface Props {
	title: string;
	period: string;
	tradition: string;
	description: string;
	why: string;
	icon: string;
	href?: string;
}

const { title, period, tradition, description, why, icon, href } = Astro.props;
---

<div class="discipline-card">
	<div class="card-header">
		<svg class="card-icon" viewBox="0 0 100 100" width="48" height="48" aria-hidden="true">
			<use href={`#${icon}`}></use>
		</svg>
	</div>

	<h3 class="card-title">{title}</h3>

	<div class="card-meta">
		<span class="period-badge">{period}</span>
		<span class="tradition-label">{tradition}</span>
	</div>

	<p class="card-description">{description}</p>

	<p class="card-why"><em>{why}</em></p>

	{href && (
		<a href={href} class="card-link">Aprender más →</a>
	)}
</div>

<style>
	.discipline-card {
		background-color: var(--color-surface);
		border-top: var(--border-thick);
		padding: var(--space-6);
		border-radius: var(--border-radius);
		transition: all var(--transition-base);
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: var(--space-3);
		height: 100%;
	}

	.discipline-card:hover {
		transform: translateY(-6px);
		background-color: var(--color-surface-hover);
		box-shadow: 0 12px 32px rgba(196, 18, 48, 0.15);
	}

	.card-header {
		display: flex;
		justify-content: center;
		margin-bottom: var(--space-2);
	}

	.card-icon {
		color: var(--color-accent);
		width: 3.5rem;
		height: 3.5rem;
	}

	.card-title {
		font-family: var(--font-heading);
		font-size: var(--font-size-2xl);
		color: var(--color-ink);
		font-weight: 400;
		margin-bottom: var(--space-2);
	}

	.card-meta {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-2);
		margin-bottom: var(--space-2);
	}

	.period-badge {
		display: inline-block;
		background-color: rgba(196, 18, 48, 0.2);
		color: var(--color-accent);
		padding: 0.25rem var(--space-2);
		border-radius: 999px;
		font-size: var(--font-size-xs);
		font-weight: 600;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		border: 1px solid rgba(196, 18, 48, 0.4);
	}

	.tradition-label {
		font-size: var(--font-size-xs);
		color: var(--color-ink-muted);
		font-weight: 500;
		font-style: italic;
	}

	.card-description {
		font-size: var(--font-size-sm);
		color: var(--color-ink);
		line-height: 1.6;
		margin-bottom: var(--space-2);
		flex-grow: 1;
	}

	.card-why {
		font-size: var(--font-size-sm);
		color: var(--color-ink-muted);
		font-style: italic;
		line-height: 1.5;
		margin-bottom: var(--space-2);
		border-top: var(--border-thin);
		padding-top: var(--space-3);
	}

	.card-why em {
		font-style: normal;
		color: var(--color-gold);
		font-weight: 500;
	}

	.card-link {
		font-family: var(--font-heading);
		font-size: var(--font-size-sm);
		color: var(--color-accent);
		text-decoration: none;
		font-weight: 600;
		letter-spacing: 0.05em;
		transition: color var(--transition-base);
		margin-top: auto;
	}

	.card-link:hover {
		color: var(--color-accent-light);
	}

	@media (max-width: 767px) {
		.discipline-card {
			padding: var(--space-4);
		}

		.card-icon {
			width: 3rem;
			height: 3rem;
		}
	}
</style>
